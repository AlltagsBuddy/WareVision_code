# WareVision - Environment Variables
# Kopiere diese Datei nach .env und passe die Werte an.

# Database
DATABASE_URL=postgresql://warevision:warevision@localhost:5432/warevision

# Redis (für Worker, später)
REDIS_URL=redis://localhost:6379/0

# JWT - WICHTIG: In Produktion starken Schlüssel verwenden!
SECRET_KEY=change-me-in-production-use-long-random-string

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Debug
DEBUG=false
